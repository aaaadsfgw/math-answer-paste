{
  "manifest_version": 3,
  "name": "Math Answer Paste",
  "version": "0.1.0",
  "description": "Send math and information-system questions to local Ollama and copy bracketed answers.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*"
  ],
  "action": {
    "default_title": "Math Answer Paste",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/content-script.js"
      ]
    }
  ],
  "options_page": "settings.html"
}
